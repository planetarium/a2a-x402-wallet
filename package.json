{
  "name": "a2a-x402-wallet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "packages:build": "pnpm --filter @a2a-x402-wallet/x402 build",
    "web:dev": "pnpm --filter a2a-x402-wallet-web dev",
    "web:build": "pnpm --filter a2a-x402-wallet-web build",
    "web:start": "pnpm --filter a2a-x402-wallet-web start",
    "cli:dev": "pnpm --filter a2a-x402-wallet-cli dev",
    "cli:install": "pnpm --filter @a2a-x402-wallet/x402 build && pnpm --filter a2a-x402-wallet-cli build && npm install -g ./apps/cli",
    "cli:uninstall": "npm uninstall -g a2a-x402-wallet-cli",
    "cli:build-binary": "pnpm --filter a2a-x402-wallet-cli build:binary",
    "web:deploy": "fly deploy --config apps/web/fly.toml",
    "web:db:generate": "pnpm --filter a2a-x402-wallet-web db:generate",
    "web:db:migrate": "pnpm --filter a2a-x402-wallet-web db:migrate",
    "registry:dev": "pnpm --filter a2a-agent-registry dev",
    "registry:build": "pnpm --filter a2a-agent-registry build",
    "registry:start": "pnpm --filter a2a-agent-registry start",
    "registry:deploy": "fly deploy --config apps/agent-registry/fly.toml",
    "registry:db:generate": "pnpm --filter a2a-agent-registry db:generate",
    "registry:db:migrate": "pnpm --filter a2a-agent-registry db:migrate",
    "registry:db:studio": "pnpm --filter a2a-agent-registry db:studio",
    "lint": "pnpm --filter a2a-x402-wallet-cli run lint && pnpm --filter a2a-x402-wallet-web run lint"
  }
}

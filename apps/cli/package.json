{
  "name": "a2a-x402-wallet-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "a2a-wallet": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:binary": "bun build src/index.ts --compile --outfile dist/a2a-wallet",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@a2a-x402-wallet/x402": "workspace:*",
    "@scure/bip32": "^1.6.2",
    "@scure/bip39": "^1.5.4",
    "commander": "^14.0.3",
    "viem": "^2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
